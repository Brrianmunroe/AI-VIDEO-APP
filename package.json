{
  "name": "ai-video-editing",
  "version": "0.1.0",
  "description": "AI-powered interview selects tool for video editors",
  "main": "./electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http-get://localhost:5173 && electron .\"",
    "build:electron": "vite build && electron-builder",
    "tokens:generate": "node scripts/generate-tokens.js",
    "rebuild:sqlite": "npm rebuild better-sqlite3"
  },
  "keywords": [
    "video-editing",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
