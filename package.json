{
  "name": "ai-video-editing",
  "version": "0.1.0",
  "description": "AI-powered interview selects tool for video editors",
  "main": "./electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http-get://localhost:5173 && electron .\"",
    "build:electron": "vite build && electron-builder",
    "build:electron:full": "node scripts/prepare-transcribe-bundle.js && npm run build:electron",
    "prepare:transcribe": "node scripts/prepare-transcribe-bundle.js",
    "tokens:generate": "node scripts/generate-tokens.js",
    "rebuild:sqlite": "npm rebuild better-sqlite3"
  },
  "build": {
    "extraResources": [
      { "from": "resources/python", "to": "python", "filter": ["**/*"] },
      { "from": "resources/transcribe_words.py", "to": "transcribe_words.py" }
    ]
  },
  "keywords": [
    "video-editing",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "whisper-node": "^0.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
